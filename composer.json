{
    "name": "k-antwi/fly",
    "description": "Fly is a Docker-based development and deployment toolkit for Laravel applications, distributed as a standalone binary.",
    "keywords": ["laravel", "docker", "deployment", "cli", "laravel-zero"],
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/k-antwi/fly/issues",
        "source": "https://github.com/k-antwi/fly"
    },
    "authors": [
        {
            "name": "Kwaku Antwi",
            "email": "kwaku.antwi@kawisoft.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel-zero/framework": "^11.0|^12.0",
        "symfony/process": "^6.0|^7.0",
        "symfony/yaml": "^6.0|^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["fly"]
}
