# ==========================================
# General App Configuration
# ==========================================
APP_NAME=fly-app
APP_SERVICE=laravel.fly
APP_ENV=local
APP_PORT=80
APP_URL=http://localhost
VITE_PORT=5173

# ==========================================
# Fly General Configuration
# ==========================================
FLY_APP_HOST=fly-app.localhost
FLY_ROUTER_DOMAIN=localhost
FLY_FILES=
FLY_SKIP_CHECKS=false

# ==========================================
# Fly Share / Expose Configuration
# ==========================================
FLY_SHARE_DOMAIN=laravel-fly.site
FLY_SHARE_SERVER_HOST=laravel-fly.site
FLY_SHARE_SERVER_PORT=8080
FLY_SHARE_DASHBOARD=4040
FLY_SHARE_TOKEN=
FLY_SHARE_SERVER=
FLY_SHARE_SUBDOMAIN=

# ==========================================
# Fly VPS Deployment Configuration
# ==========================================
FLY_SSH_USERNAME=
FLY_SSH_KEY=
FLY_REMOTE_APP_DIR=

# ==========================================
# XDebug Configuration
# ==========================================
FLY_XDEBUG_MODE=off
FLY_XDEBUG_CONFIG=client_host=host.docker.internal

# ==========================================
# Service Port Forwarding
# ==========================================
FORWARD_DB_PORT=3306
FORWARD_REDIS_PORT=6379
FORWARD_VALKEY_PORT=6379
FORWARD_MONGODB_PORT=27017
FORWARD_PGSQL_PORT=5432
FORWARD_TYPESENSE_PORT=8108
FORWARD_MINIO_PORT=9000
FORWARD_MINIO_CONSOLE_PORT=8900
FORWARD_MEMCACHED_PORT=11211
FORWARD_MEILISEARCH_PORT=7700
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025

# ==========================================
# Service Credentials & Extras
# ==========================================
MONGODB_USERNAME=
MONGODB_PASSWORD=

# Pusher & Soketi
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_METRICS_PORT=9601
VITE_PUSHER_HOST=localhost

# Odoo
ODOO_DB_CONTAINER_NAME=
ODOO_CONTAINER_NAME=
ODOO_APP_PORT=8069
ODOO_LONG_POLLING=8072
